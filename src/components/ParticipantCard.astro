---
/**
 * Bigger squared card for the About page.
 * Shows name, surname, link icon, affiliation, and role.
 */
interface Props {
  name: string;
  surname: string;
  link?: string;
  affiliation?: string;
  role?: string;
}

const { name, surname, link, affiliation, role } = Astro.props;
---

<div class="participant-card">
  <div class="participant-card__header">
    <span class="participant-card__name">{name} {surname}</span>
    {link && (
      <a href={link} target="_blank" rel="noopener" class="participant-card__link" title={`${name}'s website`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
          <polyline points="15 3 21 3 21 9" />
          <line x1="10" y1="14" x2="21" y2="3" />
        </svg>
      </a>
    )}
  </div>
  {role && <div class="participant-card__role">{role}</div>}
  {affiliation && <div class="participant-card__affiliation">{affiliation}</div>}
</div>

<style>
  .participant-card {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-sm);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
    padding: 16px 20px;
    min-width: 200px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .participant-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.07);
  }

  .participant-card__header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .participant-card__name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
  }

  .participant-card__link {
    display: flex;
    align-items: center;
    color: var(--text-tertiary);
    transition: color 0.2s;
  }

  .participant-card__link:hover {
    color: var(--blossom-deep);
  }

  .participant-card__role {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--blossom-deep);
    margin-top: 6px;
  }

  .participant-card__affiliation {
    font-size: 0.82rem;
    color: var(--text-secondary);
    margin-top: 2px;
  }
</style>
