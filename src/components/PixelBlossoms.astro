---
/**
 * Pixel art cherry blossom petals + Amsterdam canal house
 * rendered as small inline SVGs scattered in the background.
 * All pixelated via image-rendering: pixelated.
 */
---

<div class="pixel-blossoms">
  <!-- Petal cluster top-left -->
  <svg class="pixel-petal" style="top: 8%; left: 6%; width: 32px;" viewBox="0 0 8 8" xmlns="http://www.w3.org/2000/svg">
    <rect x="3" y="0" width="2" height="1" fill="#FFB7C5"/>
    <rect x="2" y="1" width="4" height="1" fill="#FFB7C5"/>
    <rect x="1" y="2" width="6" height="1" fill="#FFCDD6"/>
    <rect x="2" y="3" width="4" height="1" fill="#FFB7C5"/>
    <rect x="3" y="4" width="2" height="1" fill="#FF8FA3"/>
  </svg>

  <!-- Petal top-right -->
  <svg class="pixel-petal" style="top: 12%; right: 10%; width: 24px;" viewBox="0 0 6 6" xmlns="http://www.w3.org/2000/svg">
    <rect x="2" y="0" width="2" height="1" fill="#FFCDD6"/>
    <rect x="1" y="1" width="4" height="1" fill="#FFB7C5"/>
    <rect x="0" y="2" width="6" height="1" fill="#FFB7C5"/>
    <rect x="1" y="3" width="4" height="1" fill="#FFCDD6"/>
    <rect x="2" y="4" width="2" height="1" fill="#FFB7C5"/>
  </svg>

  <!-- Small petal mid-left -->
  <svg class="pixel-petal" style="top: 40%; left: 3%; width: 20px;" viewBox="0 0 5 5" xmlns="http://www.w3.org/2000/svg">
    <rect x="2" y="0" width="1" height="1" fill="#FFB7C5"/>
    <rect x="1" y="1" width="3" height="1" fill="#FFCDD6"/>
    <rect x="0" y="2" width="5" height="1" fill="#FFB7C5"/>
    <rect x="1" y="3" width="3" height="1" fill="#FFB7C5"/>
    <rect x="2" y="4" width="1" height="1" fill="#FF8FA3"/>
  </svg>

  <!-- Canal house pixel art — right side -->
  <svg class="pixel-petal" style="bottom: 8%; right: 4%; width: 48px; opacity: 0.2;" viewBox="0 0 12 16" xmlns="http://www.w3.org/2000/svg">
    <!-- Stepped gable -->
    <rect x="5" y="0" width="2" height="1" fill="#D4A574"/>
    <rect x="4" y="1" width="4" height="1" fill="#D4A574"/>
    <rect x="3" y="2" width="6" height="1" fill="#C4956A"/>
    <rect x="2" y="3" width="8" height="1" fill="#D4A574"/>
    <!-- Facade -->
    <rect x="1" y="4" width="10" height="10" fill="#D4A574"/>
    <!-- Windows -->
    <rect x="3" y="5" width="2" height="2" fill="#87CEEB"/>
    <rect x="7" y="5" width="2" height="2" fill="#87CEEB"/>
    <rect x="3" y="9" width="2" height="2" fill="#87CEEB"/>
    <rect x="7" y="9" width="2" height="2" fill="#87CEEB"/>
    <!-- Door -->
    <rect x="5" y="11" width="2" height="3" fill="#8B4513"/>
  </svg>

  <!-- Scattered small petals -->
  <svg class="pixel-petal" style="top: 65%; right: 15%; width: 16px;" viewBox="0 0 4 4" xmlns="http://www.w3.org/2000/svg">
    <rect x="1" y="0" width="2" height="1" fill="#FFB7C5"/>
    <rect x="0" y="1" width="4" height="2" fill="#FFCDD6"/>
    <rect x="1" y="3" width="2" height="1" fill="#FFB7C5"/>
  </svg>

  <svg class="pixel-petal" style="top: 30%; right: 5%; width: 18px;" viewBox="0 0 4 4" xmlns="http://www.w3.org/2000/svg">
    <rect x="1" y="0" width="2" height="1" fill="#FFCDD6"/>
    <rect x="0" y="1" width="4" height="2" fill="#FFB7C5"/>
    <rect x="1" y="3" width="2" height="1" fill="#FF8FA3"/>
  </svg>

  <!-- Tulip pixel art — bottom left -->
  <svg class="pixel-petal" style="bottom: 12%; left: 8%; width: 28px; opacity: 0.25;" viewBox="0 0 7 10" xmlns="http://www.w3.org/2000/svg">
    <!-- Petals -->
    <rect x="2" y="0" width="3" height="1" fill="#FF6B8A"/>
    <rect x="1" y="1" width="5" height="1" fill="#FF8FA3"/>
    <rect x="0" y="2" width="7" height="2" fill="#FF6B8A"/>
    <rect x="1" y="4" width="5" height="1" fill="#FF8FA3"/>
    <!-- Stem -->
    <rect x="3" y="5" width="1" height="4" fill="#6BBF59"/>
    <!-- Leaf -->
    <rect x="4" y="7" width="2" height="1" fill="#A8D5A2"/>
    <rect x="1" y="8" width="2" height="1" fill="#A8D5A2"/>
  </svg>
</div>
