---
// Floating action button that appears when the #we-are-here divider is offscreen.
// Points up or down depending on where the divider is relative to the viewport,
// and smooth-scrolls to it on click.
---

<button
  type="button"
  id="here-fab"
  class="here-fab"
  aria-label="Scroll to current week"
  hidden
>
  <svg class="here-fab__arrow" width="22" height="22" viewBox="0 0 24 24" fill="none"
       stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="6 9 12 15 18 9"></polyline>
  </svg>
</button>

<script>
  const fab = document.getElementById('here-fab') as HTMLButtonElement | null;
  const target = document.getElementById('we-are-here');

  if (fab && target) {
    fab.addEventListener('click', () => {
      target.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });

    const update = () => {
      const rect = target.getBoundingClientRect();
      const vh = window.innerHeight || document.documentElement.clientHeight;
      // small slack so the FAB doesn't flicker right at the boundary
      const isVisible = rect.top < vh - 40 && rect.bottom > 40;

      if (isVisible) {
        fab.hidden = true;
        return;
      }
      fab.hidden = false;
      // If divider is above the viewport, arrow points up; if below, arrow points down.
      const above = rect.bottom <= 40;
      fab.classList.toggle('here-fab--up', above);
      fab.classList.toggle('here-fab--down', !above);
    };

    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
  }
</script>
