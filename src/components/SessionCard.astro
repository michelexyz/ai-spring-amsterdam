---
interface Props {
  week: number;
  theme: 'foundation' | 'sota' | 'safety' | 'free';
  date?: string;
  paperTitle: string;
  paperUrl: string;
  paperAuthors: string;
  paperYear: number;
  description?: string;
  companionTitle: string;
  companionUrl: string;
  companionSource: string;
  companionDescription?: string;
  note?: string;
  highlight?: boolean;
  alternatives?: Array<{
    label: string;
    paperTitle: string;
    paperUrl: string;
    paperAuthors: string;
    companionTitle: string;
    companionUrl: string;
  }>;
}

const themeLabels: Record<string, string> = {
  foundation: 'Foundation',
  sota: 'State of the Art',
  safety: 'Safety',
  free: 'Free Topic',
};

const {
  week,
  theme,
  date,
  paperTitle,
  paperUrl,
  paperAuthors,
  paperYear,
  description,
  companionTitle,
  companionUrl,
  companionSource,
  companionDescription,
  note,
  highlight = false,
  alternatives,
} = Astro.props;
---

<article class={`glass-card session-card ${highlight ? 'next-session' : ''}`}>
  {highlight && <div class="label">Next Session</div>}

  <div class="meta">
    <span class={`badge badge-${theme}`}>{themeLabels[theme]}</span>
    <span>Week {week}</span>
    {date && <span>&middot; {date}</span>}
  </div>

  <div>
    <a href={paperUrl} target="_blank" rel="noopener" class="paper-title">{paperTitle}</a>
    <div class="authors">{paperAuthors}, {paperYear}</div>
  </div>

  <div class="session-description">
    {Astro.slots.has('description') ? <slot name="description" /> : <p style="margin-bottom: 0;">{description}</p>}
  </div>

  <div class="companion">
    <div class="companion-label">Companion reading</div>
    <a href={companionUrl} target="_blank" rel="noopener">{companionTitle}</a>
    <span style="color: var(--text-tertiary); font-size: 0.85rem;"> — {companionSource}</span>
    {companionDescription && (
      <p style="font-size: 0.92rem; color: var(--text-primary); margin-top: 6px; margin-bottom: 0;">
        {companionDescription}
      </p>
    )}
  </div>

  {alternatives && alternatives.length > 0 && (
    <div style="margin-top: 16px; padding-top: 16px; border-top: 1px dashed rgba(0,0,0,0.08);">
      <div class="companion-label" style="margin-bottom: 12px;">Alternative picks — vote in the group!</div>
      {alternatives.map((alt) => (
        <div style="margin-bottom: 12px; padding-left: 12px; border-left: 2px solid var(--blossom-light);">
          <strong style="font-size: 0.85rem;">{alt.label}:</strong>
          <a href={alt.paperUrl} target="_blank" rel="noopener" style="font-size: 0.85rem;"> {alt.paperTitle}</a>
          <div style="font-size: 0.8rem; color: var(--text-tertiary);">{alt.paperAuthors}</div>
          <div style="font-size: 0.8rem; color: var(--text-tertiary);">
            Companion: <a href={alt.companionUrl} target="_blank" rel="noopener">{alt.companionTitle}</a>
          </div>
        </div>
      ))}
    </div>
  )}

  <style>
    .session-description,
    .session-description :global(p),
    .session-description :global(li) {
      font-size: 0.92rem;
      color: var(--text-primary);
      line-height: 1.55;
    }
    .session-description :global(p) {
      margin: 0 0 10px;
    }
    .session-description :global(p:last-child) {
      margin-bottom: 0;
    }
    .session-description :global(h1),
    .session-description :global(h2),
    .session-description :global(h3),
    .session-description :global(h4) {
      color: var(--text-primary);
      margin: 14px 0 6px;
      line-height: 1.3;
    }
    .session-description :global(h1) { font-size: 1.25rem; }
    .session-description :global(h2) { font-size: 1.12rem; }
    .session-description :global(h3) { font-size: 1.02rem; }
    .session-description :global(h4) { font-size: 0.95rem; }
    .session-description :global(a) { color: var(--blossom, #d66); }
    .session-description :global(ul),
    .session-description :global(ol) { margin: 6px 0 10px 1.2em; }
  </style>

  {note && (
    <div style="margin-top: 12px; padding: 10px 14px; background: var(--blossom-pale); border-radius: var(--radius-sm); font-size: 0.82rem; color: var(--text-secondary);">
      {note}
    </div>
  )}
</article>
