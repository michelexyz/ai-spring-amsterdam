---
interface Props {
  activePage?: string;
}
const { activePage = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<nav>
  <div class="container">
    <a href={`${base}`} class="logo">
      <span class="blossom">🌸</span> AI Spring Amsterdam
    </a>

    <button class="nav-toggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav-links">
      <li><a href={`${base}`} class={activePage === 'home' ? 'active' : ''}>Home</a></li>
      <li><a href={`${base}about`} class={activePage === 'about' ? 'active' : ''}>About</a></li>
      <li><a href={`${base}roadmap`} class={activePage === 'roadmap' ? 'active' : ''}>Roadmap</a></li>
      <li><a href={`${base}past-sessions`} class={activePage === 'past-sessions' ? 'active' : ''}>Past Sessions</a></li>
    </ul>
  </div>
</nav>
